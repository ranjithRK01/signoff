{
  "name": "signoff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "concurrently \"next dev\" \"json-server --watch db.json --port 3001\"",
    "dev:clean": "npm run clean && npm run dev",
    "server": "json-server --watch db.json --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "json-server": "^1.0.0-beta.15",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "quill": "^2.0.2",
    "react": "^18",
    "react-dom": "^18",
    "react-quill": "^2.0.0",
    "shadcn": "^4.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/quill": "^2.0.14",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
