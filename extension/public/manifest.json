{
  "manifest_version": 3,
  "name": "QuickQA",
  "version": "0.1.0",
  "description": "Submit website feedback directly on live websites.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "cookies"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3001/*"
    ]
  },
  "action": {
    "default_title": "Open QuickQA"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
